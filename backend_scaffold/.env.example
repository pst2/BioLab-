APP_NAME=Bioinformatics Backend
APP_VERSION=0.2.0
API_V1_PREFIX=/api/v1
DEBUG=true

DATABASE_URL=sqlite:///./bio_backend.db
ALLOWED_ORIGINS=*

# Comma-separated API keys. Required in production for protected endpoints.
API_KEYS=dev-key-1,dev-key-2

NCBI_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
NCBI_API_KEY=
NCBI_TIMEOUT=15
NCBI_RETRY_COUNT=3
NCBI_RETMAX=10

CACHE_TTL_GENE_SECONDS=3600
CACHE_TTL_PUBMED_SECONDS=3600
CACHE_TTL_SEQUENCE_SECONDS=86400

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_SYSTEM=10/minute
